# AI QA Assistant API Keys Config
# Copy this file to .env and fill in your keys.

# Encryption key for provider keys stored in SQLite.
# Use a long random value and keep it stable; changing it makes existing DB keys undecryptable.
ENCRYPTION_KEY=

# Gemini API Key (Go to https://aistudio.google.com/ to get one)
GEMINI_API_KEY=

# Claude API Key (Go to https://console.anthropic.com/ to get one)
CLAUDE_API_KEY=

# OpenAI API Key (Go to https://platform.openai.com/ to get one)
OPENAI_API_KEY=
